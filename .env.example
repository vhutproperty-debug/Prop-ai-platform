# MongoDB Atlas (required)
# Get connection string from: Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/propai?retryWrites=true&w=majority

# Authentication (required, min 32 characters)
JWT_SECRET=change-this-to-a-secure-random-string-32chars

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AI (optional)
OPENAI_API_KEY=

# Firecrawl (optional — builder website imports)
FIRECRAWL_API_KEY=

# CRM (optional)
CRM_WEBHOOK_URL=

# App (required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Seed script (optional)
SEED_ADMIN_EMAIL=admin@propai.in
SEED_ADMIN_PASSWORD=PropAI@Admin123
